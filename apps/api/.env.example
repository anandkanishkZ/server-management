# PostgreSQL connection used by Prisma
DATABASE_URL="postgresql://panel:changeme@localhost:5432/panel?schema=public"

# JWT signing secret (generate with: openssl rand -hex 32)
JWT_SECRET="changeme"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"

# Server
PORT=4000
HOST="127.0.0.1"

# Path to the privileged helper's Unix socket
HELPER_SOCKET_PATH="/run/panel/helper.sock"

# The refresh-token cookie is Secure by default (required once this sits
# behind TLS). Only set to "false" for a temporary HTTP-only deployment -
# browsers silently drop Secure cookies over plain HTTP.
COOKIE_SECURE="true"

# Dedicated Postgres SUPERUSER role used ONLY by the Databases table-browser
# and SQL console (never by anything else) - needs to reach every database
# on the instance, not just the panel's own schema. Every route that uses
# this is gated behind the ADMIN role, not just "logged in".
DBA_HOST="127.0.0.1"
DBA_PORT=5432
DBA_USER="panel_dba"
DBA_PASSWORD="changeme"
