# PostgreSQL connection used by Prisma
DATABASE_URL="postgresql://panel:changeme@localhost:5432/panel?schema=public"

# JWT signing secret (generate with: openssl rand -hex 32)
JWT_SECRET="changeme"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"

# Server
PORT=4000
HOST="127.0.0.1"

# Path to the privileged helper's Unix socket
HELPER_SOCKET_PATH="/run/panel/helper.sock"
